{
    "manifest_version": 3,
    "name": "SweptJS",
    "version": "1.0.0",
    "description": "Memory & DOM lifecycle monitor for web pages",
    "permissions": [
        "storage",
        "sidePanel"
    ],
    "side_panel": {
        "default_path": "src/popup/popup.html"
    },
    "background": {
        "service_worker": "src/background.ts"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/content/content.ts"
            ],
            "all_frames": false
        }
    ],
    "action": {
        "default_popup": "src/popup/popup.html",
        "default_icon": {
            "16": "resources/logo.png",
            "48": "resources/logo.png",
            "128": "resources/logo.png"
        }
    }
}